# Copy to .env.local. Defaults point at the Supabase local stack (started via `pnpm db:start`).

# --- Local (default in dev) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-from-`supabase status -o env`>
# Server-only — never exposed to the browser. Required for member
# invitations (creates auth.users + sends magic-link emails via SMTP/Mailpit).
# Grab it from `supabase status -o env` (key: SERVICE_ROLE_KEY).
SUPABASE_SERVICE_ROLE_KEY=<service-role-from-`supabase status -o env`>
# Absolute base URL used to build the magic-link redirect when sending
# invitations server-side. Optional — falls back to the request origin.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cloud (uncomment to point at the prod project) ---
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-from-https://supabase.com/dashboard/project/.../settings/api>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-from-supabase.com/dashboard/project/.../settings/api>

# --- Quotes providers ---
# EODHD_API_KEY=<eodhd-token>
# CoinGecko demo key — optional. Without it, public rate limits apply.
# COINGECKO_API_KEY=<coingecko-demo-key>
